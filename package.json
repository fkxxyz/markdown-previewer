{
  "name": "markdown-previewer",
  "version": "0.1.0",
  "description": "Local markdown previewer web app",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "build": "cd frontend && bun install && bun run build",
    "build:frontend": "cd frontend && bun install && bun run build",
    "start": "bun run --filter '*' start",
    "dev": "bun run --filter '*' dev"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
